rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }

    // ===== PRODUCTOS =====
    // Anyone can read products (public catalog)
    match /productos/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== CATEGORIAS =====
    // Anyone can read categories (public catalog)
    match /categorias/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== MODELOS 3D =====
    // Anyone can read 3D models (public catalog)
    match /modelos3d/{modelId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== CONFIG =====
    // Public read, admin write
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== TICKETS =====
    // Users can read their own tickets, admin can read all
    match /tickets/{ticketId} {
      allow read: if isOwner(resource.data.clienteId) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(resource.data.clienteId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ===== USUARIOS =====
    // Users can only read/write their own profile
    match /usuarios/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if true; // Firebase Auth already validates email
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Prevent non-admin from setting role to admin
      allow update: if (
        isOwner(userId) || isAdmin()
      ) && (
        !('role' in request.resource.data) ||
        request.resource.data.role == null ||
        request.resource.data.role == 'admin' && isAdmin() ||
        request.resource.data.role != 'admin'
      );
    }
  }
}